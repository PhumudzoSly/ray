{
  "name": "@workspace/websocket-server",
  "version": "2.0.0",
  "description": "Rebuilt WebSocket server for Y.js collaborative editing with improved reliability and monitoring",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch & node --watch dist/server.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "clean": "rm -rf dist/",
    "deploy:local": "node deploy.js --local",
    "deploy:docker": "node deploy.js --docker",
    "deploy:railway": "node deploy.js --railway",
    "deploy:help": "node deploy.js --help"
  },
  "dependencies": {
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.27",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.8.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "yjs",
    "websocket",
    "collaborative",
    "real-time",
    "typescript"
  ],
  "license": "MIT"
}
