# WebSocket Server Configuration

# Server Port (Railway will override this)
PORT=1234   

# Environment (development, production)
NODE_ENV=development

# JWT Secret for authentication (CHANGE IN PRODUCTION!)
JWT_SECRET=your-jwt-secret-key

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Use '*' to allow all origins (NOT recommended for production)
ALLOWED_ORIGINS=http://localhost:3000,https://app.rayai.dev

# Health Check Server Port (for monitoring endpoints)
HEALTH_PORT=3005

# Rate Limiting Configuration
# Maximum connections per IP address within the time window
MAX_CONNECTIONS_PER_IP=20

# Maximum connections per authenticated user
MAX_CONNECTIONS_PER_USER=10

# Rate limit time window in milliseconds (default: 1 minute)
RATE_LIMIT_WINDOW=60000

# Security Headers (automatically enabled in production)
# These are configured in the code and don't need environment variables
# - X-Content-Type-Options: nosniff
# - X-Frame-Options: DENY
# - X-XSS-Protection: 1; mode=block
# - Referrer-Policy: strict-origin-when-cross-origin
# - Content-Security-Policy: default-src 'self'; connect-src 'self' ws: wss:; script-src 'self'; style-src 'self' 'unsafe-inline'
# - Strict-Transport-Security: max-age=31536000; includeSubDomains
# - Permissions-Policy: camera=(), microphone=(), geolocation=()