# WebSocket Server Configuration
# Copy this file to .env and modify the values as needed

# Environment
NODE_ENV=development

# Server Ports
WS_PORT=3001
HEALTH_PORT=3005

# Feature Toggles
# Enable/disable Yjs functionality (backward compatibility)
ENABLE_YJS=true
# Enable/disable general websocket functionality
ENABLE_GENERAL_WS=true
# Enable/disable presence tracking
ENABLE_PRESENCE=true
# Enable/disable channel management
ENABLE_CHANNELS=true

# Performance Settings
# Maximum connections per IP address
MAX_CONNECTIONS_PER_IP=10
# Maximum channels per connection
MAX_CHANNELS_PER_CONNECTION=50
# Heartbeat interval in milliseconds
HEARTBEAT_INTERVAL=30000
# Presence cleanup interval in milliseconds
PRESENCE_CLEANUP_INTERVAL=60000
# Connection timeout in milliseconds
CONNECTION_TIMEOUT=300000

# Security Settings
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
# Enable authentication (set to true for production)
ENABLE_AUTH=false
# JWT secret for authentication (required if ENABLE_AUTH=true)
JWT_SECRET=your-secret-key-here

# Logging Settings
# Enable detailed logging
ENABLE_DETAILED_LOGGING=false
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Rate Limiting
# Enable rate limiting
ENABLE_RATE_LIMITING=true
# Rate limit window in milliseconds
RATE_LIMIT_WINDOW=60000
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket Settings
# Enable compression
WS_COMPRESSION=true
# Maximum payload size in bytes
WS_MAX_PAYLOAD=1048576